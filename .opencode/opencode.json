{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "snapshot": true,
  "default_agent": "planner",
  "instructions": [
    "AGENTS.md",
    "docs/harness/project-context.md",
    "docs/harness/workflow.md",
    "docs/harness/validation.md",
    "docs/harness/security.md",
    "docs/harness/learnings.md"
  ],
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "watcher": {
    "ignore": [
      "**/bin/**",
      "**/obj/**",
      "TestResults/**",
      ".opencode/node_modules/**"
    ]
  },
  "tool_output": {
    "max_lines": 400,
    "max_bytes": 20000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 4
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "ask",
    "task": "ask",
    "skill": {
      "*": "allow",
      "ask": "ask",
      "experimental-*": "ask"
    },
    "edit": {
      "*": "ask",
      ".env": "deny",
      ".env.*": "deny",
      ".env.example": "ask",
      "**/.env": "deny",
      "**/secrets/**": "ask",
      "src/PaymentHub.Infrastructure.Postgres/Migrations/**": "ask"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "dotnet restore*": "allow",
      "dotnet build*": "allow",
      "dotnet test*": "allow",
      "dotnet format*": "allow",
      "docker compose config*": "allow",
      "scripts/agent-init.sh": "allow",
      "./scripts/agent-init.sh": "allow",
      "scripts/agent-verify.sh": "allow",
      "./scripts/agent-verify.sh": "allow",
      "scripts/agent-docs-check.sh": "allow",
      "./scripts/agent-docs-check.sh": "allow",
      "scripts/agent-architecture-check.sh": "allow",
      "./scripts/agent-architecture-check.sh": "allow",
      "scripts/agent-smoke.sh": "allow",
      "./scripts/agent-smoke.sh": "allow",
      "git push*": "ask",
      "git reset*": "ask",
      "git checkout*": "ask",
      "git clean*": "ask",
      "rm *": "ask",
      "rm -r*": "ask",
      "rm -f*": "ask",
      "rm -rf*": "ask"
    }
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=payment_gateway;Username=payment_gateway;Password=payment_gateway"
  },
  "PaymentHub": {
    "DefaultProvider": "Fake",
    "ApiKeyHashSecret": "dev-secret-change-me",
    "CredentialEncryptionKey": "dev-encryption-key-change-me-32bytes",
    "WebhookSecretEncryptionKey": "dev-webhook-secret-key-change-me-32bytes",
    "WebhookWorkerBatchSize": 25,
    "OutboxWorkerBatchSize": 50,
    "WebhookWorkerIntervalSeconds": 5,
    "OutboxWorkerIntervalSeconds": 2,
    "WebhookHttpTimeoutSeconds": 10
  },
  "Providers": {
    "AbacatePay": {
      "BaseUrl": "https://api.abacatepay.com/v2",
      "TimeoutSeconds": 30,
      "AllowDevModeSimulation": true
    }
  },
  "Bootstrap": {
    "Enabled": true,
    "SeedDevelopmentData": true,
    "AllowProductionBootstrap": false,
    "DevelopmentTenantSlug": "dev-tenant",
    "DevelopmentApplicationName": "dev-app",
    "DevelopmentWebhookSecret": "dev-webhook-secret-change-me"
  }
}

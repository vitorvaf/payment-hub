{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Providers": {
    "AbacatePay": {
      "BaseUrl": "https://api.abacatepay.com/v2",
      "TimeoutSeconds": 30,
      "AllowDevModeSimulation": false
    }
  },
  "Bootstrap": {
    "Enabled": false,
    "SeedDevelopmentData": false,
    "AllowProductionBootstrap": false,
    "DevelopmentTenantSlug": "dev-tenant",
    "DevelopmentApplicationName": "dev-app",
    "DevelopmentWebhookSecret": null
  }
}

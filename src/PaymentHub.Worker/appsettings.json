{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Bootstrap": {
    "Enabled": false,
    "SeedDevelopmentData": false,
    "AllowProductionBootstrap": false,
    "DevelopmentTenantSlug": "dev-tenant",
    "DevelopmentApplicationName": "dev-app"
  }
}
